{
  "name": "@mushin/workers",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "node --watch --loader ts-node/esm src/bootstrap.ts",
    "start": "node dist/bootstrap.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-sqs": "^3.700.0",
    "@mushin/config": "workspace:*",
    "@mushin/database": "workspace:*",
    "@mushin/events": "workspace:*",
    "@mushin/shared": "workspace:*",
    "drizzle-orm": "^0.38.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
