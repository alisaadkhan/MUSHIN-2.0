{
  "name": "@mushin/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "node --watch --loader ts-node/esm src/server.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@mushin/adapters": "workspace:*",
    "@mushin/config": "workspace:*",
    "@mushin/database": "workspace:*",
    "@mushin/events": "workspace:*",
    "@mushin/shared": "workspace:*",
    "@supabase/supabase-js": "^2.47.0",
    "@upstash/redis": "^1.38.0",
    "drizzle-orm": "^0.38.0",
    "hono": "^4.6.0",
    "jose": "^5.9.0",
    "jsonwebtoken": "^9.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@mushin/testing": "workspace:*",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
