{
  "dashboard": {
    "title": "MUSHIN Queue & Pipeline Health",
    "tags": ["mushin", "queue", "pipeline"],
    "timezone": "utc",
    "panels": [
      {
        "title": "Queue Depth by Class",
        "type": "timeseries",
        "targets": [{
          "expr": "mushin_queue_depth",
          "legendFormat": "{{queue_class}}"
        }],
        "thresholds": {
          "steps": [
            { "color": "green", "value": 0 },
            { "color": "yellow", "value": 100 },
            { "color": "red", "value": 1000 }
          ]
        },
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
      },
      {
        "title": "Oldest Message Age (seconds)",
        "type": "timeseries",
        "targets": [{
          "expr": "mushin_queue_oldest_message_age_s",
          "legendFormat": "{{queue_class}}"
        }],
        "thresholds": {
          "steps": [
            { "color": "green", "value": 0 },
            { "color": "yellow", "value": 300 },
            { "color": "red", "value": 900 }
          ]
        },
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
      },
      {
        "title": "DLQ Depth",
        "type": "stat",
        "targets": [{
          "expr": "mushin_queue_dlq_depth"
        }],
        "thresholds": {
          "steps": [
            { "color": "green", "value": 0 },
            { "color": "red", "value": 1 }
          ]
        },
        "gridPos": { "h": 8, "w": 6, "x": 0, "y": 8 }
      },
      {
        "title": "Job Success Rate",
        "type": "timeseries",
        "targets": [{
          "expr": "rate(mushin_jobs_completed_total[5m]) / (rate(mushin_jobs_completed_total[5m]) + rate(mushin_jobs_failed_total[5m])) * 100",
          "legendFormat": "{{job_type}}"
        }],
        "unit": "percent",
        "thresholds": {
          "steps": [
            { "color": "red", "value": 0 },
            { "color": "yellow", "value": 95 },
            { "color": "green", "value": 99 }
          ]
        },
        "gridPos": { "h": 8, "w": 18, "x": 6, "y": 8 }
      },
      {
        "title": "Outbox Relay Lag",
        "type": "timeseries",
        "targets": [{
          "expr": "mushin_outbox_relay_lag_s"
        }],
        "thresholds": {
          "steps": [
            { "color": "green", "value": 0 },
            { "color": "yellow", "value": 60 },
            { "color": "red", "value": 300 }
          ]
        },
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 }
      },
      {
        "title": "Job Duration P95",
        "type": "timeseries",
        "targets": [{
          "expr": "histogram_quantile(0.95, rate(mushin_jobs_duration_ms_bucket[5m]))",
          "legendFormat": "{{job_type}}"
        }],
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 }
      }
    ],
    "time": { "from": "now-1h", "to": "now" },
    "refresh": "30s"
  }
}
