{
  "dashboard": {
    "title": "MUSHIN API Health",
    "tags": ["mushin", "api", "health"],
    "timezone": "utc",
    "panels": [
      {
        "title": "Request Rate (RPS)",
        "type": "timeseries",
        "targets": [{
          "expr": "rate(mushin_adapter_calls_total[5m])",
          "legendFormat": "{{adapter}}"
        }],
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
      },
      {
        "title": "Error Rate",
        "type": "timeseries",
        "targets": [{
          "expr": "rate(mushin_adapter_errors_total[5m]) / rate(mushin_adapter_calls_total[5m]) * 100",
          "legendFormat": "{{adapter}}"
        }],
        "thresholds": {
          "steps": [
            { "color": "green", "value": 0 },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 5 }
          ]
        },
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
      },
      {
        "title": "Latency P95 by Adapter",
        "type": "timeseries",
        "targets": [{
          "expr": "histogram_quantile(0.95, rate(mushin_adapter_latency_ms_bucket[5m]))",
          "legendFormat": "{{adapter}}"
        }],
        "thresholds": {
          "steps": [
            { "color": "green", "value": 0 },
            { "color": "yellow", "value": 500 },
            { "color": "red", "value": 1000 }
          ]
        },
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 }
      },
      {
        "title": "Circuit Breaker State",
        "type": "stat",
        "targets": [{
          "expr": "mushin_adapter_circuit_state",
          "legendFormat": "{{adapter}}"
        }],
        "valueMaps": [
          { "value": "0", "text": "CLOSED", "color": "green" },
          { "value": "1", "text": "OPEN", "color": "red" }
        ],
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 }
      },
      {
        "title": "SLO Burn Rate",
        "type": "gauge",
        "targets": [{
          "expr": "mushin_slo_burn_rate"
        }],
        "thresholds": {
          "steps": [
            { "color": "green", "value": 0 },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 14.4 }
          ]
        },
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 }
      },
      {
        "title": "Error Budget Remaining",
        "type": "gauge",
        "targets": [{
          "expr": "mushin_slo_error_budget_remaining_seconds / 2592 * 100"
        }],
        "unit": "percent",
        "thresholds": {
          "steps": [
            { "color": "red", "value": 0 },
            { "color": "yellow", "value": 25 },
            { "color": "green", "value": 50 }
          ]
        },
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 }
      }
    ],
    "time": { "from": "now-1h", "to": "now" },
    "refresh": "30s"
  }
}
