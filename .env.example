# ============================================================
# MUSHIN 2.0 — Environment Variables Template
# Copy to .env and fill in values. NEVER commit .env.
#
# Required credentials are marked with [REQUIRED]
# Optional credentials are marked with [OPTIONAL]
# ============================================================

# ── Application ──────────────────────────────────────────────
NODE_ENV="development"
PORT=3000
APP_URL="http://localhost:3000"
ALLOWED_PREVIEW_ORIGINS="http://localhost:3000"
CORS_ORIGINS="http://localhost:3000,http://localhost:3001"

# ── Database (Supabase PostgreSQL) ─────────────────────────── [REQUIRED]
DATABASE_URL="postgresql://user:password@host:5432/mushin"
DATABASE_POOL_SIZE=10

# Supabase (frontend client)
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"
VITE_SUPABASE_PROJECT_ID="your-project-id"

# Supabase (backend — Auth API)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ── Auth (JWT / JWKS) ─────────────────────────────────────── [REQUIRED]
JWT_ISSUER="https://auth.mushin.io"
JWT_AUDIENCE="mushin-api"
JWKS_URI="https://auth.mushin.io/.well-known/jwks.json"

# ── AWS / SQS ─────────────────────────────────────────────── [REQUIRED]
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your-access-key"
AWS_SECRET_ACCESS_KEY="your-secret-key"
SQS_OUTBOX_QUEUE_URL="https://sqs.us-east-1.amazonaws.com/account/mushin-outbox"
SQS_DLQ_URL="https://sqs.us-east-1.amazonaws.com/account/mushin-dlq"
SQS_DISCOVERY_QUEUE_URL="https://sqs.us-east-1.amazonaws.com/account/mushin-discovery"
SQS_RESCORE_QUEUE_URL="https://sqs.us-east-1.amazonaws.com/account/mushin-rescore"
SQS_ERASURE_QUEUE_URL="https://sqs.us-east-1.amazonaws.com/account/mushin-erasure"

# ── Meilisearch (Brain 1 — fast deterministic search) ─────── [REQUIRED]
MEILISEARCH_HOST="https://your-meilisearch.ms-eu-west-1.svc.meilisearch.io"
MEILISEARCH_API_KEY="your-meilisearch-master-key"
MEILISEARCH_SEARCH_KEY="your-meilisearch-search-key"

# ── LLM Providers ───────────────────────────────────────────
# T-A: Groq llama-3.1-8b-instant (classification, extraction) [REQUIRED]
GROQ_API_KEY="your-groq-api-key"

# T-C: Anthropic claude-sonnet-4-5 (ambiguous authenticity) [OPTIONAL]
ANTHROPIC_API_KEY="your-anthropic-api-key"

# Fallback: OpenAI gpt-4o-mini / gpt-4o [OPTIONAL]
OPENAI_API_KEY="your-openai-api-key"

# HuggingFace Inference (T-A fallback) [OPTIONAL]
HUGGINGFACE_API_KEY="your-huggingface-key"

# ── External API Adapters ────────────────────────────────────
# Serper (Google SERP — Discovery) [REQUIRED]
SERPER_API_KEY="your-serper-key"

# Apify (managed scraping actors) [REQUIRED]
APIFY_API_KEY="your-apify-key"
APIFY_INSTAGRAM_ACTOR_ID="your-instagram-actor-id"
APIFY_TIKTOK_ACTOR_ID="your-tiktok-actor-id"
APIFY_YOUTUBE_ACTOR_ID="your-youtube-actor-id"

# YouTube Data API v3 [OPTIONAL]
YOUTUBE_API_KEY="your-youtube-api-key"

# Phyllo (creator verification) [OPTIONAL]
PHYLLO_API_KEY="your-phyllo-key"
PHYLLO_SECRET_KEY="your-phyllo-secret"

# ── Paddle (Billing — MoR) ────────────────────────────────── [REQUIRED]
PADDLE_API_KEY="your-paddle-api-key"
PADDLE_WEBHOOK_SECRET="your-paddle-webhook-signing-secret"
PADDLE_ENVIRONMENT="sandbox"

# ── Resend (Transactional email) ──────────────────────────── [REQUIRED]
RESEND_API_KEY="your-resend-key"
RESEND_FROM_EMAIL="noreply@yourdomain.com"
RESEND_FROM_ADDRESS="noreply@yourdomain.com"
RESEND_FROM_NAME="MUSHIN"

# ── Cloudflare Turnstile (bot protection) [OPTIONAL] ──────────
VITE_TURNSTILE_SITE_KEY="your-turnstile-site-key"
TURNSTILE_SECRET_KEY="your-turnstile-secret-key"

# ── Observability ────────────────────────────────────────────
# Axiom (structured logs) [REQUIRED]
AXIOM_TOKEN="your-axiom-token"
AXIOM_DATASET="mushin-production"

# Grafana Cloud (metrics + traces) [OPTIONAL]
GRAFANA_CLOUD_INSTANCE_ID="your-grafana-instance-id"
GRAFANA_CLOUD_API_KEY="your-grafana-api-key"

# Sentry (error tracking) [REQUIRED]
SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"
SENTRY_AUTH_TOKEN="your-sentry-auth-token"
SENTRY_ORG="your-sentry-org"
SENTRY_PROJECT="your-sentry-project"

# PostHog (product analytics) [OPTIONAL]
VITE_POSTHOG_KEY="your-posthog-key"
VITE_POSTHOG_HOST="https://us.i.posthog.com"
VITE_POSTHOG_UI_HOST="https://us.posthog.com"

# ── Feature Flags (Unleash) [OPTIONAL] ──────────────────────
UNLEASH_URL="https://your-unleash-instance.com/api"
UNLEASH_API_TOKEN="your-unleash-api-token"
UNLEASH_APP_NAME="mushin-api"

# ── Worker & Cache ──────────────────────────────────────────
WORKER_SECRET="your-worker-secret"
UPSTASH_REDIS_REST_URL="https://your-redis.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-redis-token"

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ── Idempotency ──────────────────────────────────────────────
IDEMPOTENCY_TTL_HOURS=24

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL="info"

# ── Deployment ───────────────────────────────────────────────
# Vercel [REQUIRED for deployment]
VERCEL_TOKEN="your-vercel-token"
VERCEL_ORG_ID="your-vercel-org-id"
VERCEL_PROJECT_ID="your-vercel-project-id"

# ── Test Environment Seeds ───────────────────────────────────
SEED_TEST_EMAIL="test@mushin.app"
SEED_TEST_PASSWORD="TestPassword123!"
TEST_DATABASE_URL="postgresql://test:test@localhost:5432/mushin_test"
